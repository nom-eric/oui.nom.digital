---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BrandMark from "../../components/BrandMark.astro";

const title = "Mentions légales · Øui";
const description = "Informations légales relatives à l’édition et à l’hébergement du site Øui.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <main class="container">
    <section class="hero stack article">
      <header>
        <h1>Mentions légales</h1>
        <p class="article__desc">
          Un cadre clair.<br />
          Une structure simple.<br />
          Rien de plus.
        </p>
      </header>
    </section>

    <section class="stack">
      <h2>Éditeur du site</h2>
      <p>
        Le présent site est édité par Eric BRUET, entrepreneur individuel.<br />
        <BrandMark prefix="" suffix="ui" ariaLabel="Øui" /> est une marque éditoriale exploitée par cette entreprise.
      </p>
      <p>
        Adresse de domiciliation : 10 rue Pasteur, 73160 Cognin, France<br />
        Téléphone : 06 60 81 68 39<br />
        E-mail :
        <a href="mailto:oui@oui.nom.digital?subject=Legal">oui@oui.nom.digital</a>
      </p>
      <p>
        SIREN : 102 758 554<br />
        SIRET : 102 758 554 00012<br />
        Immatriculation au RCS : Chambéry
