---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BrandMark from "../../components/BrandMark.astro";

const title = "Øui · Comment on devient lisible";
const description =
  "Un essai PDF bref et structuré sur la manière dont une présence numérique devient lisible, stable et calculable.";

const canonical = "/ebook/";
const lemonUrl =
  "https://studioeditorial.lemonsqueezy.com/checkout/buy/38a4dda1-d127-4d58-8c12-2964162f058c?embed=1&logo=0";
const coverUrl = "/couv.png";
---

<BaseLayout title={title} description={description} canonical={canonical} bodyClass="ebook">
  <section class="ebook-hero">
    <div class="ebook-hero__grid">
      <div class="ebook-hero__content article">
        <header>
          <h1>
            <BrandMark prefix="" suffix="ui" ariaLabel="Øui" />
          </h1>

          <p class="article__desc">Comment on devient lisible</p>

          <p class="lede">
            Un essai sur les gestes ordinaires par lesquels une présence numérique devient
            stable, retrouvable, associable, puis calculable.
          </p>

          <div class="cta-row cta-row--left hero-cta-row">
            <a class="btn primary lemonsqueezy-button" href={lemonUrl}>
              Acheter l’ebook — 12,99 €
            </a>
            <a class="btn" href="#details">
              Voir les détails
            </a>
          </div>
        </header>

        <div class="intro-lines intro-lines--indent">
          <p class="intro-line">Un essai bref, dense et structuré.</p>
          <p class="intro-line">Ni manuel de protection, ni discours spectaculaire.</p>
          <p class="intro-line">Un texte pour comprendre avant d’agir.</p>
        </div>
      </div>

      <aside class="ebook-cover card">
        <img
          src={coverUrl}
          alt="Couverture de Øui — Comment on devient lisible, par Maël Nor"
          loading="eager"
        />
      </aside>
    </div>
  </section>

  <section class="grid-2 ebook-grid" id="details" aria-label="Présentation de l’ebook Øui">
    <div class="card ebook-main">
      <p class="section-title">Pourquoi lire Øui</p>

      <p>
        <BrandMark prefix="" suffix="ui" ariaLabel="Øui" /> ne traite pas la visibilité
        comme un thème abstrait. Le livre suit les seuils par lesquels une présence vécue
        devient une présence stable, lisible et exploitable.
      </p>

      <p>
        Créer un compte. Relier des services. Laisser une trace. Devenir retrouvable.
        Être associé. Être anticipé. Se retirer. Être lu par des systèmes.
      </p>

      <ul class="list">
        <li>un essai bref, dense et structuré ;</li>
        <li>un cadre pour comprendre avant d’agir ;</li>
        <li>un texte pour celles et ceux que les discours simplistes sur le numérique fatiguent.</li>
      </ul>
    </div>

    <aside class="card ebook-side">
      <p class="section-title">Acheter l’ebook</p>

      <div class="meta-list">
        <p><strong>Format</strong> <span>PDF</span></p>
        <p><strong>Pagination</strong> <span>96 pages</span></p>
        <p><strong>Auteur</strong> <span>Maël Nor</span></p>
        <p><strong>Éditeur</strong> <span>Studio Editorial</span></p>
        <p><strong>ISBN</strong> <span>979-10-085480-0-0</span></p>
        <p><strong>Prix</strong> <span>12,99 €</span></p>
      </div>

      <p class="small note">
        Téléchargement immédiat après achat via Lemon Squeezy.
      </p>
    </aside>
  </section>

  <script src="https://assets.lemonsqueezy.com/lemon.js" defer></script>

  <style>
    .ebook-hero {
      margin-bottom: var(--s6);
    }

    .ebook-hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(260px, 380px);
      gap: var(--s5);
      align-items: start;
    }

    .ebook-hero__content {
      width: 100%;
    }

    .kicker {
      margin: 0 0 .5rem;
      font-size: .95rem;
      opacity: .7;
      font-weight: 650;
      letter-spacing: .01em;
    }

    .lede {
      max-width: 62ch;
      opacity: .88;
    }

    .hero-cta-row {
      margin-top: var(--s4);
    }

    .proof {
      margin-top: var(--s3);
    }

    .ebook-cover {
      padding: var(--s2);
      background: var(--surface);
      position: sticky;
      top: 84px;
    }

    .ebook-cover img {
      display: block;
      width: 100%;
      border-radius: calc(var(--radius) - 6px);
      border: 1px solid var(--line);
      background: var(--surface-2);
    }

    .ebook-grid {
      align-items: start;
      margin-top: 0;
    }

    .ebook-main,
    .ebook-side {
      background: var(--surface);
    }

    .ebook-main {
      gap: var(--s3);
    }

    .ebook-side {
      position: sticky;
      top: 84px;
      gap: var(--s3);
    }

    .section-title {
      font-weight: 800;
      letter-spacing: -0.01em;
    }

    .meta-list {
      display: grid;
      gap: .55rem;
    }

    .meta-list p {
      display: flex;
      justify-content: space-between;
      gap: var(--s3);
      padding-bottom: .55rem;
      border-bottom: 1px solid var(--line);
    }

    .meta-list span {
      text-align: right;
    }

    .note {
      opacity: .82;
    }

    @media (max-width: 900px) {
      .ebook-hero__grid,
      .ebook-grid {
        grid-template-columns: 1fr;
      }

      .ebook-cover,
      .ebook-side {
        position: static;
        top: auto;
      }

      .ebook-cover {
        max-width: 420px;
      }
    }
  </style>
</BaseLayout>